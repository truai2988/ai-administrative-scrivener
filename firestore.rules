rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // -------------------------------------------------------------------------
    // Utility Functions
    // -------------------------------------------------------------------------
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserRole() {
      let docData = getUserData();
      return docData != null ? docData.data.get('role', 'none') : 'none';
    }

    function getUserOrganizationId() {
      let docData = getUserData();
      return docData != null ? docData.data.get('organizationId', 'none') : 'none';
    }

    function isScrivener()   { return getUserRole() == 'scrivener'; }
    function isUnionStaff() { return getUserRole() == 'union_staff'; }
    function isEnterpriseStaff() { return getUserRole() == 'enterprise_staff'; }

    // 行政書士は全データ閲覧可
    function canViewAllForeigners() {
      return isScrivener();
    }

    // 特定の外国人データに対するアクセス権限があるか
    function hasForeignerAccess(foreignerData) {
      return canViewAllForeigners() ||
             (isUnionStaff() && foreignerData.get('unionId', '') == getUserOrganizationId()) ||
             (isEnterpriseStaff() && foreignerData.get('enterpriseId', '') == getUserOrganizationId());
    }


    // -------------------------------------------------------------------------
    // /users コレクション
    // -------------------------------------------------------------------------
    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if false;

      // ── マッピング学習データ（Click-to-Fill Auto-Fill 用） ──
      // 自身のサブコレクションのみ読み書き可
      match /mappingPreferences/{docId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    // -------------------------------------------------------------------------
    // /dynamic_applications コレクション
    // -------------------------------------------------------------------------
    match /dynamic_applications/{docId} {
      // get: ドキュメントが存在しない場合は resource が null になるため、
      // docId に userId が含まれていることで所有権を確認する
      allow get: if isAuthenticated() && docId.matches('draft_' + request.auth.uid + '_.*');
      // list: 認証済みユーザーのみ（クエリで userId フィルタを前提）
      allow list: if isAuthenticated();
      // create: 書き込みデータの userId が自分自身であること
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // update/delete: 既存ドキュメントの所有者のみ
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // -------------------------------------------------------------------------
    // /organizations コレクション
    // -------------------------------------------------------------------------
    match /organizations/{orgId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // -------------------------------------------------------------------------
    // /branches コレクション (旧/後方互換用) - 削除またはOrganizationsで代用
    // -------------------------------------------------------------------------


    // -------------------------------------------------------------------------
    // /foreigners コレクション
    // -------------------------------------------------------------------------
    match /foreigners/{foreignerId} {
      
      // ===== 読み取り =====
      // 未認証ユーザーもURLトークンを知っていれば対象データのみ読み取り可能（getDoc用）
      allow get: if true; 
      
      allow list: if isAuthenticated() && hasForeignerAccess(resource.data);

      // ===== 作成 =====
      // - 行政書士・管理者: 認証済みユーザーによる作成
      // - 未認証: 外国人本人が申請フォームから作成する場合（URLトークン = ドキュメントID）
      allow create: if 
        // 認証済みユーザーによる作成（既存ルール）
        (isAuthenticated() && (
          ( (isUnionStaff() || isEnterpriseStaff()) && hasForeignerAccess(request.resource.data) )
        )) ||
        // 未認証ユーザー（外国人本人）による申請フォームからの作成
        (!isAuthenticated() && request.resource.data.keys().hasAll(['name', 'updatedAt']));

      // ===== 更新 =====
      // - scrivener: 全データ更新可（ステータス変更含む）
      // - hq_admin: 本部直轄（branchId == 'hq_direct'）のデータのみ更新可
      // - branch_staff: 自支部のデータのみ更新可（支部ID変更不可）
      // - 修正時、status を「編集中」に変更し、approvalStatus を null または削除することは全認証ユーザー（管理・書士・事務員）に許可する
      allow update: if 
        // 認証済みユーザーによる更新
        (isAuthenticated() && (
          isScrivener() ||
          (
            (isUnionStaff() || isEnterpriseStaff()) &&
            hasForeignerAccess(resource.data) &&
            request.resource.data.get('unionId', '') == resource.data.get('unionId', '') &&
            request.resource.data.get('enterpriseId', '') == resource.data.get('enterpriseId', '') &&
            (
              !('status' in request.resource.data) ||
              request.resource.data.status == resource.data.get('status', '') ||
              request.resource.data.status == '編集中'
            )
          )
        )) ||
        // 未認証ユーザー（外国人本人）による申請フォームからの更新
        // ステータス変更・isEditedByAdmin変更は不可
        (!isAuthenticated() &&
          request.resource.data.keys().hasAll(['name', 'updatedAt']) &&
          (!('status' in request.resource.data) || request.resource.data.status == resource.data.status) &&
          (!('isEditedByAdmin' in request.resource.data) || request.resource.data.isEditedByAdmin == resource.data.get('isEditedByAdmin', false))
        );

      // ===== 承認ワークフロー専用更新 =====
      // union_staff/enterprise_staff: draft/returned → pending_review への遷移のみ許可
      // approvalStatus, status, updatedAt 以外フィールド変更禁止（hasOnly制約）
      allow update: if
        isAuthenticated() &&
        ( (isUnionStaff() || isEnterpriseStaff()) && hasForeignerAccess(resource.data) ) &&
        (resource.data.get('approvalStatus', 'draft') in ['draft', 'returned'] || resource.data.get('approvalStatus', null) == null) &&
        request.resource.data.approvalStatus == 'pending_review' &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['approvalStatus', 'status', 'returnReason', 'updatedAt']);

      // scrivener: approved/returned への遷移（差し戻し理由も同時書き込み可）
      allow update: if
        isAuthenticated() &&
        isScrivener() &&
        resource.data.get('approvalStatus', 'draft') == 'pending_review' &&
        request.resource.data.approvalStatus in ['approved', 'returned'] &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['approvalStatus', 'status', 'returnReason', 'updatedAt']);

      // 緊急修復用：バグで不正なステータスになったデータを「差し戻し」に戻す処理は、認証ユーザーなら誰でも許可する
      allow update: if
        isAuthenticated() &&
        resource.data.get('approvalStatus', 'draft') == 'returned' &&
        request.resource.data.status == '差し戻し';

      // ===== 削除 =====
      allow delete: if isAuthenticated() && (
        isScrivener() || 
        ( (isUnionStaff() || isEnterpriseStaff()) && hasForeignerAccess(resource.data) )
      );
    }

    // -------------------------------------------------------------------------
    // /foreigners/{foreignerId}/correction_histories サブコレクション
    // -------------------------------------------------------------------------
    match /foreigners/{foreignerId}/correction_histories/{historyId} {
      allow read: if isAuthenticated() && (
        ( (isUnionStaff() || isEnterpriseStaff()) && hasForeignerAccess(get(/databases/$(database)/documents/foreigners/$(foreignerId)).data) ) || canViewAllForeigners()
      );
      
      allow create: if isAuthenticated() && (
                      isScrivener() ||
                      ( (isUnionStaff() || isEnterpriseStaff()) && hasForeignerAccess(get(/databases/$(database)/documents/foreigners/$(foreignerId)).data) )
                    ) && 
                    request.resource.data.keys().hasAll(['reason', 'diff', 'correctedBy', 'foreignerId', 'correctedAt']);
                    
      allow update, delete: if false;
    }

    // -------------------------------------------------------------------------
    // /renewal_applications コレクション
    // 在留期間更新許可申請書フォームのデータを管理するコレクション
    // -------------------------------------------------------------------------
    match /renewal_applications/{applicationId} {
      // ===== 読み取り =====
      // 認証済みユーザーなら全件読み取り可（一覧・単件・クエリ）
      allow read: if isAuthenticated();

      // ===== 作成 =====
      // 認証済みユーザー（行政書士・管理者・支部事務員）による作成を許可
      allow create: if isAuthenticated();

      // ===== 更新 =====
      // 認証済みユーザーによる更新を許可（編集ステータスへの遷移）
      allow update: if isAuthenticated();

      // ===== 削除 =====（物理削除は全ロール禁止）
      allow delete: if false;
    }

    // -------------------------------------------------------------------------
    // /change_of_status_applications コレクション
    // 在留資格変更許可申請書フォームのデータを管理するコレクション
    // -------------------------------------------------------------------------
    match /change_of_status_applications/{applicationId} {
      // ===== 読み取り =====
      // 認証済みユーザーなら全件読み取り可（一覧・単件・クエリ）
      allow read: if isAuthenticated();

      // ===== 作成 =====
      // 認証済みユーザー（行政書士・管理者・支部事務員）による作成を許可
      allow create: if isAuthenticated();

      // ===== 更新 =====
      // 認証済みユーザーによる更新を許可（編集ステータスへの遷移）
      allow update: if isAuthenticated();

      // ===== 削除 =====（物理削除は全ロール禁止）
      allow delete: if false;
    }

    // -------------------------------------------------------------------------
    // /coe_applications コレクション
    // 在留資格認定証明書交付申請書フォームのデータを管理するコレクション
    // -------------------------------------------------------------------------
    match /coe_applications/{applicationId} {
      // ===== 読み取り =====
      // 認証済みユーザーなら全件読み取り可（一覧・単件・クエリ）
      allow read: if isAuthenticated();

      // ===== 作成 =====
      // 認証済みユーザー（行政書士・管理者・支部事務員）による作成を許可
      allow create: if isAuthenticated();

      // ===== 更新 =====
      // 認証済みユーザーによる更新を許可（編集ステータスへの遷移）
      allow update: if isAuthenticated();

      // ===== 削除 =====（物理削除は全ロール禁止）
      allow delete: if false;
    }

    // -------------------------------------------------------------------------
    // /foreigner_stats コレクション
    // 集計パターンのためのサマリードキュメント
    // -------------------------------------------------------------------------
    match /foreigner_stats/{statId} {
      allow read: if isAuthenticated() && (
        canViewAllForeigners() || statId == getUserOrganizationId() || statId == 'global'
      );
      // ドキュメントの増減はクライアントが行うため認証ユーザーに許可
      allow write: if isAuthenticated();
    }

    // -------------------------------------------------------------------------
    // /system_settings コレクション
    // システム全体の設定（テンプレートなど）を管理するコレクション
    // -------------------------------------------------------------------------
    match /system_settings/{document=**} {
      // 読み取りは全ユーザー（認証問わず）に許可。未ログインからのフォーム生成でもテンプレートを使うため
      allow read: if true;
      // 書き込みは認証済みユーザー（現在はダミーを含むため広め、本来は isScrivener() とする）
      allow write: if isAuthenticated();
    }

    // -------------------------------------------------------------------------
    // /document_templates コレクション
    // テンプレートマスターメタデータを管理するコレクション
    // -------------------------------------------------------------------------
    match /document_templates/{templateId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isScrivener();
    }

    // -------------------------------------------------------------------------
    // /company_masters コレクション
    // 企業マスタ情報を管理するコレクション
    // -------------------------------------------------------------------------
    match /company_masters/{masterId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // -------------------------------------------------------------------------
    // /union_masters コレクション
    // 組合マスタ情報を管理するコレクション
    // -------------------------------------------------------------------------
    match /union_masters/{masterId} {
      allow read: if isAuthenticated() && (
        isScrivener() ||
        (isUnionStaff() && resource.data.organizationId == getUserOrganizationId())
      );
      allow create: if isAuthenticated() && isScrivener();
      allow update: if isAuthenticated() && (
        isScrivener() ||
        (isUnionStaff() && resource.data.organizationId == getUserOrganizationId() && request.resource.data.organizationId == resource.data.organizationId)
      );
      allow delete: if isAuthenticated() && isScrivener();
    }

    // -------------------------------------------------------------------------
    // /inquiries コレクション
    // サポートへの問い合わせ
    // -------------------------------------------------------------------------
    match /inquiries/{inquiryId} {
      // 管理側または自身が作成した問い合わせのみ読み取りを許可
      allow read: if isAuthenticated() && (isScrivener() || resource.data.userId == request.auth.uid);
      // 作成・更新はServer Actionで行うため基本はクライアント側書き込み不可
      // （※リアルタイムでステータス変更する場合は更新もServer Actionで行う）
      allow write: if false;
    }
  }
}
