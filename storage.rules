rules_version = '2';

/**
 * Firebase Storage セキュリティルール
 *
 * ファイル保存パス構造:
 *   applications/{applicationId}/{tabId}/{fileName}
 *
 * タブID (tabId): 'foreignerInfo' | 'employerInfo' | 'simultaneous'
 *
 * 権限マトリクス:
 *  | ロール         | 読み取り | 書き込み | 削除 |
 *  |----------------|----------|----------|------|
 *  | scrivener      | ○        | ○        | ○    |
 *  | union_staff    | ○        | 担当タブのみ | 担当タブのみ |
 *  | enterprise_staff| ○        | 担当タブのみ | 担当タブのみ |
 */
service firebase.storage {
  match /b/{bucket}/o {

    // ─── ヘルパー関数 ────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      let userDoc = firestore.get(/databases/(default)/documents/users/$(request.auth.uid));
      return userDoc != null ? userDoc.data.role : 'none';
    }

    function isScrivener()   { return getUserRole() == 'scrivener'; }
    function isUnionStaff() { return getUserRole() == 'union_staff'; }
    function isEnterpriseStaff() { return getUserRole() == 'enterprise_staff'; }

    /** scrivener は全権限を持つグローバル管理者 */
    function isGlobalAdmin() {
      return isScrivener();
    }

    /**
     * union_staff / enterprise_staff が特定の申請書の特定タブへの書き込み権限を持つか判定。
     * Firestore の renewal_applications/{applicationId} ドキュメントの
     * formData.assignments[tabId] に自身のUID が設定されている場合のみ許可。
     */
    function isStaffAssignedToTab(applicationId, tabId) {
      let appData = firestore.get(
        /databases/(default)/documents/renewal_applications/$(applicationId)
      ).data;
      return (isUnionStaff() || isEnterpriseStaff()) &&
             appData != null &&
             appData.formData != null &&
             appData.formData.assignments != null &&
             appData.formData.assignments[tabId] == request.auth.uid;
    }

    // ─── ファイルバリデーション ───────────────────────────────────────────────

    /** アップロード可能なMIMEタイプ */
    function isAllowedMimeType() {
      return request.resource.contentType in [
        'image/jpeg',
        'image/png',
        'image/webp',
        'application/pdf'
      ];
    }

    /** 最大ファイルサイズ: 25MB */
    function isWithinSizeLimit() {
      return request.resource.size <= 25 * 1024 * 1024;
    }

    function isValidUpload() {
      return isAllowedMimeType() && isWithinSizeLimit();
    }

    // ─── メインルール ─────────────────────────────────────────────────────────

    /**
     * applications/{applicationId}/{tabId}/{fileName}
     *
     * 例: applications/renewal_AB12345678CD_M2K4X/foreignerInfo/passport_20260404.pdf
     */
    match /applications/{applicationId}/{tabId}/{fileName} {

      /** 読み取り: 認証済みユーザー全員 */
      allow read: if isAuthenticated();

      /**
       * 書き込み（アップロード）:
       * - グローバル管理者（scrivener）: 常時許可
       * - union_staff/enterprise_staff: 当該タブの担当者のみ、かつバリデーション通過
       */
      allow write: if isAuthenticated() && isValidUpload() && (
        isGlobalAdmin() ||
        isStaffAssignedToTab(applicationId, tabId)
      );

      /**
       * 削除:
       * - グローバル管理者: 常時許可
       * - union_staff/enterprise_staff: 当該タブの担当者のみ
       */
      allow delete: if isAuthenticated() && (
        isGlobalAdmin() ||
        isStaffAssignedToTab(applicationId, tabId)
      );
    }

    /**
     * templates/{formId}/{fileType}/{fileName}
     *
     * 行政書士・管理者による原本テンプレートアップロード用
     */
    match /templates/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write, delete: if isAuthenticated(); // クロスサービス参照エラーを回避するため一時的に緩和
    }

    /**
     * foreigners/{tempId}/{fileName}
     *
     * 申請人がアカウント作成前にパスポートや顔写真をアップロードするため、
     * バリデーション付きで未認証の書き込みを許可する。読み取りは認証済みユーザーのみ。
     */
    match /foreigners/{tempId}/{fileName} {
      allow write: if isValidUpload();
      allow read: if isAuthenticated();
    }

    // その他のパスはすべてのアクセスを拒否
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
