    {
      "sectionKey": "trainingStatus",
      "sectionLabel": "２．技能実習実施状況",
      "fields": [
        {
          "fieldKey": "trainingYear",
          "label": "対象年",
          "zodType": "z.number().int().min(1900).max(2100)",
          "validation": {
            "maxLength": null,
            "minLength": null,
            "regex": null,
            "regexDescription": null
          },
          "csvHeader": "training_year",
          "sectionKey": "trainingStatus",
          "isRequired": true,
          "isRepeatable": false,
          "repeatMax": null,
          "enumValues": null,
          "description": "この月のデータが対象とする年（例: 2017）",
          "csvSpec": "半角数字4桁",
          "isComputed": false,
          "dependencies": [],
          "computedLogic": null
        },
        {
          "fieldKey": "monthlyReports",
          "label": "月別実習状況",
          "zodType": "z.array(z.object({ month: z.number().int().min(1).max(12), scheduledDays: z.number().int().min(0), attendanceDays: z.number().int().min(0), attendanceRate: z.string().regex(/^\\d+(\\.\\d{1,2})?$/), absentDays: z.number().int().min(0), paidLeaveDays: z.number().int().min(0) })).length(12)",
          "validation": {
            "maxLength": null,
            "minLength": null,
            "regex": null,
            "regexDescription": null
          },
          "csvHeader": "monthly_reports",
          "sectionKey": "trainingStatus",
          "isRequired": true,
          "isRepeatable": true,
          "repeatMax": 12,
          "enumValues": null,
          "description": "各月の実習予定日数、出勤日数、出勤率、欠勤日数、有給取得日数を記録します。12ヶ月分必須。",
          "csvSpec": "このフィールドはCSV出力時に月別に展開されます (例: scheduled_days_01, attendance_days_01, ...)",
          "isComputed": false,
          "dependencies": [],
          "computedLogic": null
        },
        {
          "fieldKey": "totalScheduledDays",
          "label": "合計 実習予定日数",
          "zodType": "z.number().int().min(0)",
          "validation": {
            "maxLength": null,
            "minLength": null,
            "regex": null,
            "regexDescription": null
          },
          "csvHeader": "total_scheduled_days",
          "sectionKey": "trainingStatus",
          "isRequired": true,
          "isRepeatable": false,
          "repeatMax": null,
          "enumValues": null,
          "description": "対象年間の実習予定日数の合計",
          "csvSpec": "半角数字",
          "isComputed": true,
          "dependencies": [
            "monthlyReports"
          ],
          "computedLogic": "(monthlyReports) => monthlyReports.reduce((sum, m) => sum + (Number(m.scheduledDays) || 0), 0)"
        },
        {
          "fieldKey": "totalAttendanceDays",
          "label": "合計 出勤日数",
          "zodType": "z.number().int().min(0)",
          "validation": {
            "maxLength": null,
            "minLength": null,
            "regex": null,
            "regexDescription": null
          },
          "csvHeader": "total_attendance_days",
          "sectionKey": "trainingStatus",
          "isRequired": true,
          "isRepeatable": false,
          "repeatMax": null,
          "enumValues": null,
          "description": "対象年間の出勤日数の合計",
          "csvSpec": "半角数字",
          "isComputed": true,
          "dependencies": [
            "monthlyReports"
          ],
          "computedLogic": "(monthlyReports) => monthlyReports.reduce((sum, m) => sum + (Number(m.attendanceDays) || 0), 0)"
        },
        {
          "fieldKey": "totalAttendanceRate",
          "label": "合計 出勤率",
          "zodType": "z.string().regex(/^\\d+(\\.\\d{1,2})?$/)",
          "validation": {
            "maxLength": null,
            "minLength": null,
            "regex": "^\\d+(\\.\\d{1,2})?$",
            "regexDescription": "半角数字、小数点以下2桁まで"
          },
          "csvHeader": "total_attendance_rate",
          "sectionKey": "trainingStatus",
          "isRequired": true,
          "isRepeatable": false,
          "repeatMax": null,
          "enumValues": null,
          "description": "対象年間の出勤率の合計（％）",
          "csvSpec": "半角数字、小数点以下2桁まで",
          "isComputed": true,
          "dependencies": [
            "totalScheduledDays",
            "totalAttendanceDays"
          ],
          "computedLogic": "(totalScheduledDays, totalAttendanceDays) => totalScheduledDays > 0 ? ((totalAttendanceDays / totalScheduledDays) * 100).toFixed(2) : '0.00'"
        },
        {
          "fieldKey": "totalAbsentDays",
          "label": "合計 欠勤日数",
          "zodType": "z.number().int().min(0)",
          "validation": {
            "maxLength": null,
            "minLength": null,
            "regex": null,
            "regexDescription": null
          },
          "csvHeader": "total_absent_days",
          "sectionKey": "trainingStatus",
          "isRequired": true,
          "isRepeatable": false,
          "repeatMax": null,
          "enumValues": null,
          "description": "対象年間の欠勤日数の合計",
          "csvSpec": "半角数字",
          "isComputed": true,
          "dependencies": [
            "monthlyReports"
          ],
          "computedLogic": "(monthlyReports) => monthlyReports.reduce((sum, m) => sum + (Number(m.absentDays) || 0), 0)"
        },
        {
          "fieldKey": "totalPaidLeaveDays",
          "label": "合計 有給取得日数",
          "zodType": "z.number().int().min(0)",
          "validation": {
            "maxLength": null,
            "minLength": null,
            "regex": null,
            "regexDescription": null
          },
          "csvHeader": "total_paid_leave_days",
          "sectionKey": "trainingStatus",
          "isRequired": true,
          "isRepeatable": false,
          "repeatMax": null,
          "enumValues": null,
          "description": "対象年間の有給取得日数の合計",
          "csvSpec": "半角数字",
          "isComputed": true,
          "dependencies": [
            "monthlyReports"
          ],
          "computedLogic": "(monthlyReports) => monthlyReports.reduce((sum, m) => sum + (Number(m.paidLeaveDays) || 0), 0)"
        }
      ]
    },
